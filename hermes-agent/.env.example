# ---- Hermes Agent config -------------------------------------------------
# Copy this file to ".env" (in this hermes-agent folder) and fill it in.

# Where the dashboard lives. Local default below; on the VPS this is your domain.
DASHBOARD_URL=http://localhost:3000

# Must match INGEST_TOKEN in the dashboard's .env (the bearer token).
INGEST_TOKEN=dev-ingest-token-change-me

# ---- Model intelligence: set ONE of these to your provider key -----------
# The agent auto-detects which one is present.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides:
# Force a provider (anthropic | openai | gemini | openrouter) instead of auto-detect.
# HERMES_PROVIDER=
# Override the default model id for the chosen provider.
# HERMES_MODEL=

# How many of the freshest items to analyze per run (keeps the map readable + cost low).
HERMES_MAX_ITEMS=8
