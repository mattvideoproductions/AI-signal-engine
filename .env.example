# --- Required ---

# Password for the dashboard UI. All pages are locked behind this.
# Use a long random string in production.
APP_PASSWORD=

# Bearer token Hermes (or any client) must send to POST /api/events.
# Generate one with:  openssl rand -hex 32
INGEST_TOKEN=

# Local data file. Keep the default for Docker (mounted volume at ./data).
DATA_FILE=./data/signal.json

# Display name
NEXT_PUBLIC_APP_NAME=AI Signal Engine

# Enables the "Start Demo Scan" button (seeded fake-but-realistic events).
DEMO_MODE=true

# --- Optional (future LLM enrichment — NOT required for the app to function) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
